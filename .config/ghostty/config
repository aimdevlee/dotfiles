auto-update = check
auto-update-channel = stable
background-opacity = 0.95
background-blur = 20
confirm-close-surface = always
copy-on-select = true
cursor-style-blink = false
shell-integration-features = no-cursor
font-family = PlemolJP Console NF
font-family = NanumGothicCoding
font-feature = -dlig
font-size = 16
adjust-cell-height = 14
title = " "

# Ctrl+number → tmux window switching (CSI u encoding)
keybind = ctrl+1=text:\x1b[49;5u
keybind = ctrl+2=text:\x1b[50;5u
keybind = ctrl+3=text:\x1b[51;5u
keybind = ctrl+4=text:\x1b[52;5u
keybind = ctrl+5=text:\x1b[53;5u
keybind = ctrl+6=text:\x1b[54;5u
keybind = ctrl+7=text:\x1b[55;5u
keybind = ctrl+8=text:\x1b[56;5u
keybind = ctrl+9=text:\x1b[57;5u

keybind = super+shift+\=new_split:right
keybind = super+shift+-=new_split:down
keybind = super+shift+left=goto_split:left
keybind = super+shift+down=goto_split:down
keybind = super+shift+up=goto_split:up
keybind = super+shift+right=goto_split:right
keybind = super+i=inspector:toggle
keybind = super+r=reload_config
keybind = cmd+s=toggle_quick_terminal
macos-titlebar-style = transparent
macos-option-as-alt = left
mouse-hide-while-typing = true
quick-terminal-animation-duration = 0.08
quick-terminal-position = center
shell-integration = zsh
shell-integration-features = no-cursor
theme = TokyoNight
window-padding-x = 4
window-padding-balance = true
window-padding-color = extend
